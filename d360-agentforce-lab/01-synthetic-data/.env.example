# Salesforce Developer Edition credentials
# Copy this file to .env and fill in your values
#
# Authentication: We use SF CLI OAuth (sf org login web) instead of
# username/password. The script grabs the access token from the CLI.
# No password or security token needed in this file.

# Databricks (for Phase 2)
# Get your workspace URL from your browser when logged in
# Generate a PAT: User Settings → Developer → Access Tokens
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-personal-access-token
